# Backend environment variables
# Copy this to .env and set real values
JWT_SECRET_KEY=your-secret-key-change-this
SUPABASE_URL=https://your-supabase-url
SUPABASE_KEY=your-service-role-or-api-key
# A one-time token to create an admin via /api/admin/create
# Change this to a secure value before using in production
ADMIN_CREATION_TOKEN=dev_admin_token_change_me
# On macOS, port 5000 is often used by AirPlay; use 5001 to avoid conflict
PORT=5001
